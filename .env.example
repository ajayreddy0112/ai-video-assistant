# ── LLM ──────────────────────────────────────────────────────────────────────
# Get a free key from https://console.mistral.ai/
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ── Whisper (local, optional override) ───────────────────────────────────────
# tiny | base | small | medium | large
# Use "tiny" or "base" on small machines / Streamlit Cloud free tier.
WHISPER_MODEL=small

# ── Sarvam (only needed for Hinglish transcription) ──────────────────────────
# Get a key from https://www.sarvam.ai/
SARVAM_API_KEY=
SARVAM_STT_MODEL=saaras:v2.5

# ── Pipeline tuning (optional) ───────────────────────────────────────────────
# CHUNK_MINUTES=10
# MAX_VIDEO_MINUTES=20
# EMBEDDING_MODEL=all-MiniLM-L6-v2
